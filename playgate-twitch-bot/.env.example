# PlayGate Twitch Bot — environment.
# Copy to .env. Secrets live here; non-secret tuning lives in config.yaml.

# --- PlayGate server ---
# Host API key from POST /api/hosts/register, and the room to issue codes for.
PLAYGATE_HOST_API_KEY=
PLAYGATE_ROOM_ID=

# --- Twitch application (https://dev.twitch.tv/console) ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Optional overrides (handy for Docker; otherwise set these in config.yaml) ---
# PLAYGATE_API_BASE=http://localhost:8080
# PLAYGATE_WEB_BASE=http://localhost:5173
# TWITCH_CHANNEL_LOGIN=mychannel
# TWITCH_BOT_LOGIN=mybot
# ADMIN_PORT=8090
# ADMIN_BIND=127.0.0.1   # containers set 0.0.0.0 (published only to localhost)
