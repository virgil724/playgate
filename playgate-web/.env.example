# PlayGate web environment configuration.
# Copy to .env.local and adjust for your deployment.

# playgate-server REST API base URL (register/rooms/tokens/redeem).
VITE_API_BASE_URL=http://localhost:8080

# playgate-signaling Cloudflare Worker base URL (SDP/ICE exchange + TURN creds).
VITE_SIGNALING_BASE_URL=http://localhost:8787
